+function openBrowser(url: string) {
+	if (process.env.OPEN_BROWSER?.trim().toLowerCase() === "false") return;
+
+	const command =
+		platform === "win32" ? "cmd" : platform === "darwin" ? "open" : "xdg-open";
+	const args = platform === "win32" ? ["/c", "start", "", url] : [url];
+
+	try {
+		const child = spawn(command, args, { detached: true, stdio: "ignore" });
+		child.unref();
+	} catch (error) {
+		console.warn(`Could not open browser for ${url}:`, error);
+	}
+}
+
+type LanAddress = {
+	address: string;
+	interfaceName: string;
+	netmask: string;
+};
+
+const MDNS_ADDRESS = "224.0.0.251";
+const MDNS_PORT = 5353;
+
+function getLanAddresses(peerAddress?: string) {
+	return getLanAddressEntries(peerAddress).map((entry) => entry.address);
+}
+
+function getLanAddressEntries(peerAddress?: string) {
+	const entries: LanAddress[] = [];
+
+	for (const [interfaceName, interfaceEntries] of Object.entries(networkInterfaces())) {
+		for (const entry of interfaceEntries ?? []) {
+			if (entry.family !== "IPv4" || entry.internal) continue;
+			if (entry.address.startsWith("169.254.")) continue;
+			entries.push({ address: entry.address, interfaceName, netmask: entry.netmask });
+		}
+	}
+
+	const physicalEntries = entries.filter((entry) => !isVirtualInterface(entry.interfaceName));
+	const candidates = physicalEntries.length ? physicalEntries : entries;
+	const sameSubnetEntries = peerAddress
+		? candidates.filter((entry) => isSameSubnet(entry.address, peerAddress, entry.netmask))
+		: [];
+
+	return (sameSubnetEntries.length ? sameSubnetEntries : candidates).sort(
+		(a, b) =>
+			Number(isPrivateAddress(b.address)) - Number(isPrivateAddress(a.address)) ||
+			a.address.localeCompare(b.address, undefined, { numeric: true })
+	);
+}
+
+function getLanUrls(portSuffix: string) {
+	return getLanAddresses().map((address) => `http://${address}${portSuffix}`);
+}
+
+function isPrivateAddress(address: string) {
+	return /^(10\.|192\.168\.|172\.(1[6-9]|2\d|3[01])\.)/.test(address);
+}
+
+function isVirtualInterface(name: string) {
+	return /(?:loopback|docker|veth|vEthernet|virtual|vmware|virtualbox|vbox|hyper-v|wsl|tailscale|zerotier|vpn|tap|tunnel|utun|bridge|br-)/i.test(
+		name
+	);
+}
+
+function isSameSubnet(address: string, peerAddress: string, netmask: string) {
+	const addressNumber = ipv4ToNumber(address);
+	const peerNumber = ipv4ToNumber(peerAddress);
+	const maskNumber = ipv4ToNumber(netmask);
+	if (addressNumber === null || peerNumber === null || maskNumber === null) return false;
+	return (addressNumber & maskNumber) === (peerNumber & maskNumber);
+}
+
+function ipv4ToNumber(address: string) {
+	const parts = address.split(".").map(Number);
+	if (parts.length !== 4 || parts.some((part) => !Number.isInteger(part) || part < 0 || part > 255)) {
+		return null;
+	}
+	return parts.reduce((value, part) => (value << 8) + part, 0) >>> 0;
+}
+
+function startMdnsResponder(localHost: string) {
+	const mdnsHost = localHost.toLowerCase();
+	const socket = createSocket({ type: "udp4", reuseAddr: true });
+
+	socket.on("error", (error) => {
+		console.warn(`Could not start mDNS responder for ${localHost}:`, error);
+		socket.close();
+	});
+
+	socket.on("message", (message, remote) => {
+		const response = createMdnsResponse(message, mdnsHost, remote.address);
+		if (!response) return;
+		socket.send(response, 0, response.length, remote.port, remote.address);
+		sendMdnsMulticast(socket, response);
+	});
+
+	socket.bind(MDNS_PORT, () => {
+		try {
+			socket.setMulticastTTL(255);
+			socket.setMulticastLoopback(false);
+			const entries = getLanAddressEntries();
+			for (const entry of entries) {
+				try {
+					socket.addMembership(MDNS_ADDRESS, entry.address);
+				} catch (error) {
+					console.warn(`Could not join mDNS on ${entry.interfaceName} (${entry.address}):`, error);
+				}
+			}
+			if (!entries.length) socket.addMembership(MDNS_ADDRESS);
+			const announcement = createMdnsAnnouncement(mdnsHost);
+			if (announcement) sendMdnsMulticast(socket, announcement);
+			console.log(`🏷️ mDNS responder: http://${localHost}`);
+		} catch (error) {
+			console.warn(`Could not announce ${localHost} over mDNS:`, error);
+		}
+	});
+}
+
+function sendMdnsMulticast(socket: Socket, message: Buffer) {
+	const entries = getLanAddressEntries();
+	if (!entries.length) {
+		socket.send(message, 0, message.length, MDNS_PORT, MDNS_ADDRESS);
+		return;
+	}
+
+	let sent = false;
+	for (const entry of entries) {
+		try {
+			socket.setMulticastInterface(entry.address);
+			socket.send(message, 0, message.length, MDNS_PORT, MDNS_ADDRESS);
+			sent = true;
+		} catch (error) {
+			console.warn(`Could not send mDNS on ${entry.interfaceName} (${entry.address}):`, error);
+		}
+	}
+	if (!sent) socket.send(message, 0, message.length, MDNS_PORT, MDNS_ADDRESS);
+}
+
+function createMdnsAnnouncement(hostname: string) {
+	const addresses = getLanAddresses();
+	if (!addresses.length) return null;
+
+	const name = encodeDnsName(hostname);
+	const answers = addresses.map((address) => createARecord(name, address, 120));
+	return createDnsMessage(0, Buffer.alloc(0), answers);
+}
+
+function createMdnsResponse(query: Buffer, hostname: string, peerAddress: string) {
+	if (query.length < 12) return null;
+
+	const questionCount = query.readUInt16BE(4);
+	let offset = 12;
+	const questions: { name: Buffer; type: number; raw: Buffer }[] = [];
+
+	for (let index = 0; index < questionCount; index += 1) {
+		const parsedName = readDnsName(query, offset);
+		if (!parsedName) return null;
+		offset = parsedName.offset;
+		if (offset + 4 > query.length) return null;
+
+		const type = query.readUInt16BE(offset);
+		const raw = query.subarray(parsedName.start, offset + 4);
+		offset += 4;
+		questions.push({ name: parsedName.nameBuffer, type, raw });
+	}
+
+	const addresses = getLanAddresses(peerAddress);
+	if (!addresses.length) return null;
+
+	const answers: Buffer[] = [];
+	for (const question of questions) {
+		const name = decodeDnsName(question.name).toLowerCase();
+		if (name !== hostname || (question.type !== 1 && question.type !== 255)) continue;
+		for (const address of addresses) answers.push(createARecord(question.name, address, 120));
+	}
+	if (!answers.length) return null;
+
+	const questionsBuffer = Buffer.concat(questions.map((question) => question.raw));
+	return createDnsMessage(query.readUInt16BE(0), questionsBuffer, answers, questions.length);
+}
+
+function createDnsMessage(id: number, questions: Buffer, answers: Buffer[], questionCount = 0) {
+	const header = Buffer.alloc(12);
+	header.writeUInt16BE(id, 0);
+	header.writeUInt16BE(0x8400, 2);
+	header.writeUInt16BE(questionCount, 4);
+	header.writeUInt16BE(answers.length, 6);
+	return Buffer.concat([header, questions, ...answers]);
+}
+
+function createARecord(name: Buffer, address: string, ttl: number) {
+	const record = Buffer.alloc(10);
+	record.writeUInt16BE(1, 0);
+	record.writeUInt16BE(0x8001, 2);
+	record.writeUInt32BE(ttl, 4);
+	record.writeUInt16BE(4, 8);
+	return Buffer.concat([name, record, Buffer.from(address.split(".").map(Number))]);
+}
+
+function encodeDnsName(name: string) {
+	const parts = name.replace(/\.$/, "").split(".");
+	return Buffer.concat([
+		...parts.map((part) => Buffer.concat([Buffer.from([Buffer.byteLength(part)]), Buffer.from(part)])),
+		Buffer.from([0])
+	]);
+}
+
+function readDnsName(message: Buffer, offset: number) {
+	const start = offset;
+	while (offset < message.length) {
+		const length = message[offset];
+		if ((length & 0xc0) !== 0) return null;
+		offset += 1;
+		if (length === 0) {
+			const nameBuffer = message.subarray(start, offset);
+			return { nameBuffer, offset, start };
+		}
+		if (offset + length > message.length) return null;
+		offset += length;
+	}
+
+	return null;
+}
+
+function decodeDnsName(name: Buffer) {
+	const parts: string[] = [];
+	let offset = 0;
+
+	while (offset < name.length) {
+		const length = name[offset];
+		offset += 1;
+		if (length === 0) break;
+		parts.push(name.subarray(offset, offset + length).toString("utf8"));
+		offset += length;
+	}
+
+	return parts.join(".");
+}
